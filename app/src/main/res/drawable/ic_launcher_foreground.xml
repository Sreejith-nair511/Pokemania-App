<?xml version="1.0" encoding="utf-8"?>
<!--
    App icon foreground — stylised Pokéball design with neon glow treatment.
    Drawn within the 72dp safe zone (centred in the 108dp canvas → offset 18dp each side).
    All artwork is original geometry; no copyrighted assets reproduced.

    Design breakdown:
      • Outer ring          — neon blue stroke circle
      • Top half fill       — dark navy with blue tint
      • Bottom half fill    — very dark, near-black
      • Horizontal divider  — neon blue line across centre
      • Centre button ring  — neon blue outer ring
      • Centre button fill  — dark core with inner highlight
      • Four radar/scan arcs inside top half — subtle neon lines
      • "UPD" micro-label removed (too small at icon size)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Outer glow halo (soft, behind everything) ── -->
    <path
        android:pathData="M54,54 m-36,0 a36,36 0 1,0 72,0 a36,36 0 1,0 -72,0">
        <aapt:attr name="android:fillColor"
            xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="38">
                <item android:offset="0.0" android:color="#0000D4FF" />
                <item android:offset="0.75" android:color="#2200D4FF" />
                <item android:offset="1.0"  android:color="#5500D4FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Top half of ball (neon blue-tinted dark) ── -->
    <!-- Arc: centre 54,54 radius 33 — top semicircle -->
    <path
        android:pathData="M21,54 A33,33 0 0,1 87,54 Z"
        android:fillColor="#0D1F3C" />

    <!-- Top half gradient overlay for depth -->
    <path
        android:pathData="M21,54 A33,33 0 0,1 87,54 Z">
        <aapt:attr name="android:fillColor"
            xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="21"
                android:endX="54"   android:endY="54">
                <item android:offset="0.0" android:color="#3300D4FF" />
                <item android:offset="1.0" android:color="#0000D4FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ── Bottom half of ball (very dark) ── -->
    <path
        android:pathData="M21,54 A33,33 0 0,0 87,54 Z"
        android:fillColor="#070E1C" />

    <!-- ── Outer ring stroke ── -->
    <!-- Simulated with a filled ring: outer circle minus inner circle -->
    <!-- Outer filled circle r=33 -->
    <path
        android:pathData="M54,54 m-33,0 a33,33 0 1,0 66,0 a33,33 0 1,0 -66,0"
        android:fillColor="#00000000"
        android:strokeColor="#00D4FF"
        android:strokeWidth="2.2" />

    <!-- ── Horizontal centre divider ── -->
    <path
        android:pathData="M21,54 L87,54"
        android:fillColor="#00000000"
        android:strokeColor="#00D4FF"
        android:strokeWidth="2.2" />

    <!-- ── Radar scan arcs inside top half (decorative) ── -->
    <!-- Arc 1 — innermost, r=10 -->
    <path
        android:pathData="M44,54 A10,10 0 0,1 64,54"
        android:fillColor="#00000000"
        android:strokeColor="#00D4FF"
        android:strokeWidth="0.9"
        android:strokeAlpha="0.5" />
    <!-- Arc 2 — r=17 -->
    <path
        android:pathData="M37,54 A17,17 0 0,1 71,54"
        android:fillColor="#00000000"
        android:strokeColor="#00D4FF"
        android:strokeWidth="0.9"
        android:strokeAlpha="0.35" />
    <!-- Arc 3 — r=24 -->
    <path
        android:pathData="M30,54 A24,24 0 0,1 78,54"
        android:fillColor="#00000000"
        android:strokeColor="#00D4FF"
        android:strokeWidth="0.9"
        android:strokeAlpha="0.2" />

    <!-- ── Vertical tick marks on divider (like a device readout) ── -->
    <path android:pathData="M38,51 L38,54" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="1" android:strokeAlpha="0.6"/>
    <path android:pathData="M46,52 L46,54" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="1" android:strokeAlpha="0.6"/>
    <path android:pathData="M62,52 L62,54" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="1" android:strokeAlpha="0.6"/>
    <path android:pathData="M70,51 L70,54" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="1" android:strokeAlpha="0.6"/>

    <!-- ── Centre button — outer ring ── -->
    <path
        android:pathData="M54,54 m-8,0 a8,8 0 1,0 16,0 a8,8 0 1,0 -16,0"
        android:fillColor="#050A14"
        android:strokeColor="#00D4FF"
        android:strokeWidth="2" />

    <!-- Centre button — inner fill with radial glow -->
    <path
        android:pathData="M54,54 m-5.5,0 a5.5,5.5 0 1,0 11,0 a5.5,5.5 0 1,0 -11,0">
        <aapt:attr name="android:fillColor"
            xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="5.5">
                <item android:offset="0.0" android:color="#FF00D4FF" />
                <item android:offset="0.5" android:color="#880A1628" />
                <item android:offset="1.0" android:color="#FF050A14" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Centre button — small specular highlight -->
    <path
        android:pathData="M51.5,51.5 a1.8,1.8 0 1,0 3.6,0 a1.8,1.8 0 1,0 -3.6,0"
        android:fillColor="#66FFFFFF" />

    <!-- ── Bottom half subtle grid lines (Pokédex screen feel) ── -->
    <path android:pathData="M28,63 L80,63" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="0.5" android:strokeAlpha="0.15"/>
    <path android:pathData="M25,70 L83,70" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="0.5" android:strokeAlpha="0.1"/>
    <path android:pathData="M24,77 L84,77" android:fillColor="#00000000"
        android:strokeColor="#00D4FF" android:strokeWidth="0.5" android:strokeAlpha="0.07"/>

    <!-- ── Small neon dot accents on the outer ring (N/S/E/W) ── -->
    <path android:pathData="M54,21 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0"
        android:fillColor="#00D4FF" />
    <path android:pathData="M54,87 m-1.5,0 a1.5,1.5 0 1,0 3,0 a1.5,1.5 0 1,0 -3,0"
        android:fillColor="#00D4FF" />
    <path android:pathData="M21,54 m0,-1.5 a1.5,1.5 0 1,0 0,3 a1.5,1.5 0 1,0 0,-3"
        android:fillColor="#BB86FC" />
    <path android:pathData="M87,54 m0,-1.5 a1.5,1.5 0 1,0 0,3 a1.5,1.5 0 1,0 0,-3"
        android:fillColor="#BB86FC" />

</vector>
