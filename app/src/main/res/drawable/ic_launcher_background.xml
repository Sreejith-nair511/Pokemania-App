<?xml version="1.0" encoding="utf-8"?>
<!--
    App icon background — deep space gradient with subtle star dots
    108×108dp adaptive icon safe zone: artwork should sit within the inner 72dp
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep space base fill -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z"
        android:fillColor="#050A14" />

    <!-- Radial glow from centre — neon blue tint -->
    <path
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor"
            xmlns:aapt="http://schemas.android.com/aapt">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="60">
                <item android:offset="0.0" android:color="#2200D4FF" />
                <item android:offset="0.55" android:color="#0A0A1E1A" />
                <item android:offset="1.0"  android:color="#00050A14" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Corner purple accent glow (top-right) -->
